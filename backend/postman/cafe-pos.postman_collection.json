      "name": "Auth",
      "item": [
        {
          "name": "Register Employee",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo Employee\",\n  \"email\": \"employee{{$timestamp}}@cafepos.com\",\n  \"password\": \"employee123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Creates an employee user. Admin users are created by the DB seed."
          }
        },
        {
          "name": "Login Admin - Save JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('jwtToken', json.token);",
                  "  pm.collectionVariables.set('jwtToken', json.token);",
                  "}",
                  "if (json.user) {",
                  "  pm.environment.set('userId', json.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "JWT automation: saves response token into jwtToken."
          }
        },
        {
          "name": "Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
